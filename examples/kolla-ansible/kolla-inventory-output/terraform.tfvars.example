# Copy to terraform.tfvars and adjust for your cluster.

cloud       = "openstack"
name_prefix = "kolla"

network_name = "kolla-mgmt-net"

control_count = 3
compute_count = 2
storage_count = 0

control_flavor = "m1.large"
compute_flavor = "m1.xlarge"
storage_flavor = "m1.large"
image_name     = "ubuntu-22.04"

public_key = "ssh-ed25519 AAAA... you@example.com"

security_group_names  = ["default"]
ansible_user          = "ubuntu"
inventory_output_path = "generated/multinode"

tags = ["managed-by:terraform", "env:lab", "example:kolla-inventory-output"]
