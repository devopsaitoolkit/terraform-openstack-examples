# Copy to terraform.tfvars and adjust for your cloud.
# (terraform.tfvars is gitignored so you never commit environment specifics.)

cloud      = "openstack"
role_name  = "member"
user_id    = "00000000000000000000000000000000" # `openstack user show <name> -f value -c id`
project_id = "11111111111111111111111111111111" # `openstack project show <name> -f value -c id`
