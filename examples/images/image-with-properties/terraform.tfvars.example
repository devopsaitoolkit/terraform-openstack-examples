# Copy to terraform.tfvars and adjust for your cloud.
# (terraform.tfvars is gitignored so you never commit environment specifics.)

cloud            = "openstack"
image_name       = "ubuntu-22.04-tuned"
image_source_url = "https://cloud-images.ubuntu.com/jammy/current/jammy-server-cloudimg-amd64.img"
disk_format      = "qcow2"
container_format = "bare"
web_download     = true
min_disk_gb      = 8
min_ram_mb       = 512

properties = {
  os_distro     = "ubuntu"
  architecture  = "x86_64"
  hw_disk_bus   = "scsi"
  hw_scsi_model = "virtio-scsi"
}

tags = ["managed-by:terraform", "os:ubuntu", "tuned:virtio-scsi"]
