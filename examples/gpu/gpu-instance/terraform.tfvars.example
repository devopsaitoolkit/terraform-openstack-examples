# Copy to terraform.tfvars and adjust for your cloud.
# (terraform.tfvars is gitignored so you never commit environment specifics.)

cloud           = "openstack"
instance_name   = "gpu-instance-01"
gpu_flavor_name = "g1.large"
image_name      = "ubuntu-22.04-cuda"
network_name    = "private"
key_pair_name   = "my-keypair"

# GPU hosts are often grouped into a dedicated AZ / host aggregate.
availability_zone = "gpu-az"

security_group_names = ["default"]

# Optional: verify the GPU is visible after boot.
user_data = <<-EOT
  #cloud-config
  runcmd:
    - nvidia-smi || echo "GPU driver not ready"
EOT

tags = ["managed-by:terraform", "team:ml", "accel:gpu"]
