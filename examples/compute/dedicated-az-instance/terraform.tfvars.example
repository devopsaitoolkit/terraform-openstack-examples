# Copy to terraform.tfvars and adjust for your cloud.
# (terraform.tfvars is gitignored so you never commit environment specifics.)

cloud             = "openstack"
instance_name     = "az-pinned-01"
availability_zone = "nova"

# Optional: pin placement near a specific host by its management IP.
# Leave empty to let the Nova scheduler choose within the AZ.
build_near_host_ip = ""

flavor_name   = "m1.small"
image_name    = "ubuntu-22.04"
network_name  = "private"
key_pair_name = "my-keypair"

security_group_names = ["default"]
tags                 = ["managed-by:terraform", "env:dev", "placement:dedicated"]
