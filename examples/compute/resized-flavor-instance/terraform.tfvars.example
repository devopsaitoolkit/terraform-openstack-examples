# Copy to terraform.tfvars and adjust for your cloud.
# (terraform.tfvars is gitignored so you never commit environment specifics.)

cloud         = "openstack"
instance_name = "app-01"

# The flavor is resolved by capacity: the smallest flavor with at least this
# many vCPUs and this much RAM (MB). To resize, raise these and re-apply.
flavor_vcpus = 2
flavor_ram   = 4096

image_name    = "ubuntu-22.04"
network_name  = "private"
key_pair_name = "my-keypair"

security_group_names = ["default"]
tags                 = ["managed-by:terraform", "env:dev", "app:api"]
