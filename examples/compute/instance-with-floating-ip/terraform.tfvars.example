# Copy to terraform.tfvars and adjust for your cloud.
# (terraform.tfvars is gitignored so you never commit environment specifics.)

cloud         = "openstack"
instance_name = "web-public-01"
flavor_name   = "m1.small"
image_name    = "ubuntu-22.04"
network_name  = "private"

# External network the floating IP is allocated from.
floating_ip_pool = "public"

# Security group IDs applied to the port. Look these up with
# `openstack security group list`. An empty list uses the network default.
security_group_ids = []

key_pair_name = "my-keypair"
tags          = ["managed-by:terraform", "env:dev", "app:web"]
