# Copy to terraform.tfvars and adjust for your cloud.
cloud              = "openstack"
volume_type_name   = "multiattach"
volume_name        = "example-shared-volume"
volume_size        = 10
first_instance_id  = "11111111-1111-1111-1111-111111111111"
second_instance_id = "22222222-2222-2222-2222-222222222222"
