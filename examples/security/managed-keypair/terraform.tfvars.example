# Copy to terraform.tfvars and adjust for your cloud.
# (terraform.tfvars is gitignored so you never commit environment specifics.)
#
# Generate a key pair locally and paste ONLY the public half here:
#   ssh-keygen -t ed25519 -f ~/.ssh/openstack_ed25519 -C "you@example.com"
#   cat ~/.ssh/openstack_ed25519.pub

cloud        = "openstack"
keypair_name = "alice-ed25519"

public_key = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAExampleExampleExampleExampleExampleExample you@example.com"
