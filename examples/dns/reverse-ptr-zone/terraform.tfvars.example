# Copy to terraform.tfvars and adjust for your cloud.
# (terraform.tfvars is gitignored so you never commit environment specifics.)

cloud = "openstack"

# Reverse zone for 192.0.2.0/24 -> "2.0.192.in-addr.arpa."
reverse_zone_name = "2.0.192.in-addr.arpa."
email             = "hostmaster@example.com"
zone_ttl          = 3600

# PTR for 192.0.2.10 -> host10.example.com.
ptr_name    = "10.2.0.192.in-addr.arpa."
ptr_records = ["host10.example.com."]
ptr_ttl     = 3600
