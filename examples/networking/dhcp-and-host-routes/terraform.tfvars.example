# Copy to terraform.tfvars and adjust for your cloud.
# (terraform.tfvars is gitignored so you never commit environment specifics.)

cloud = "openstack"

network_name     = "example-dhcp-network"
subnet_name      = "example-dhcp-subnet"
cidr             = "10.80.0.0/24"
dns_nameservers  = ["1.1.1.1", "8.8.8.8"]
allocation_start = "10.80.0.10"
allocation_end   = "10.80.0.200"

host_routes = [
  {
    destination_cidr = "10.99.0.0/16"
    next_hop         = "10.80.0.1"
  },
]
