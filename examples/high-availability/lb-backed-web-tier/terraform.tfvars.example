# Copy to terraform.tfvars and adjust for your cloud.
# (terraform.tfvars is gitignored so you never commit environment specifics.)

cloud         = "openstack"
name_prefix   = "web-tier"
member_count  = 3
flavor_name   = "m1.small"
image_name    = "ubuntu-22.04"
network_name  = "private"
subnet_name   = "private-subnet"
key_pair_name = "my-keypair"

listener_port      = 80
member_port        = 80
lb_method          = "ROUND_ROBIN"
health_monitor_url = "/"

# The web instances must allow the member port from the load balancer subnet.
security_group_names = ["default", "web"]
tags                 = ["managed-by:terraform", "env:prod", "role:web"]
