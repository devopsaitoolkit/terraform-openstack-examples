# Copy to terraform.tfvars and adjust for your cloud.
# (terraform.tfvars is gitignored so you never commit environment specifics.)

cloud          = "openstack"
name_prefix    = "ha-node"
instance_count = 3
# "anti-affinity" = strict distinct hosts; "soft-anti-affinity" = best effort.
affinity_policy = "anti-affinity"
flavor_name     = "m1.small"
image_name      = "ubuntu-22.04"
network_name    = "private"
key_pair_name   = "my-keypair"

security_group_names = ["default"]
tags                 = ["managed-by:terraform", "env:prod", "role:ha"]
