# Copy to terraform.tfvars and adjust for your cloud.
# (terraform.tfvars is gitignored so you never commit environment specifics.)

cloud                 = "openstack"
router_name           = "app-router"
external_network_name = "public"
enable_snat           = true

# One router interface is created per subnet. openstack subnet list
subnet_ids = [
  "11111111-1111-1111-1111-111111111111", # web-subnet
  "22222222-2222-2222-2222-222222222222", # app-subnet
  "33333333-3333-3333-3333-333333333333", # db-subnet
]

tags = ["managed-by:terraform", "env:prod", "team:platform"]
